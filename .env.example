# Copy to .env and adjust as needed.
# ---------------------------------------------------------------------------
# Section 1: Optional Docker Compose stack (docker-compose.yml)
# ---------------------------------------------------------------------------
# Only used if you run `docker compose up`. Test-only credentials for a
# local, disposable environment -- never reuse them anywhere real.
# NOT used by examples/enterprise_setup.py.

POSTGRES_USER=ikigov
POSTGRES_PASSWORD=ikigov_test_pw
POSTGRES_DB=ikigov_test

MYSQL_ROOT_PASSWORD=ikigov_root_pw
MYSQL_USER=ikigov
MYSQL_PASSWORD=ikigov_test_pw
MYSQL_DATABASE=ikigov_test

# MSSQL requires: 8+ chars, upper+lower+digit+symbol
MSSQL_SA_PASSWORD=IkiGov_Test_Pw1!

# ---------------------------------------------------------------------------
# Section 2: examples/enterprise_setup.py -- direct connection strings
# ---------------------------------------------------------------------------
# Point the script at any running Postgres/MySQL/MSSQL server (local install,
# managed/cloud instance, or the Docker Compose stack above). Leave unset to
# skip that dialect / rely on SQLite instead. Never used to start or manage a
# database process -- these are read, not executed.
#
# Uncomment and fill in the ones you need:

IKIGOV_POSTGRES_URL=postgresql://ikigov:ikigov_test_pw@localhost:5432/ikigov_test
IKIGOV_MYSQL_URL=mysql+pymysql://root:ikigov_root_pw@localhost:3306/ikigov_test
IKIGOV_MSSQL_URL=mssql+pyodbc://sa:IkiGov_Test_Pw1!@localhost:1433/ikigov_test?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes

# ---------------------------------------------------------------------------
# Section 3: governance config profile selection (config_loader.py)
# ---------------------------------------------------------------------------
# Selects governance.<env>.yaml (e.g. config/governance.dev.yaml) or an
# explicit config file. See README.md "Config resolution order".

IKIGOV_ENV=dev
IKIGOV_CONFIG=config/governance.yaml

# ---------------------------------------------------------------------------
# Section 4: per-role database account passwords (config/governance.yaml)
# ---------------------------------------------------------------------------
# Set `account.password_env: <VAR_NAME>` for a role in governance.yaml, then
# define that VAR_NAME here instead of committing a plaintext password.
# Roles without a password/password_env configured are skipped -- never
# given a shared or guessed password. One suggested variable per built-in
# role (rename to match whatever you set as password_env):

ADMIN_DB_PASSWORD=Adm1n_Iki_Test_Pw!
DATA_OWNER_DB_PASSWORD=DataOwner_Iki_Test_Pw!
DATA_STEWARD_DB_PASSWORD=DataSteward_Iki_Test_Pw!
ANALYST_DB_PASSWORD=Analyst_Iki_Test_Pw!
AUDITOR_DB_PASSWORD=Auditor_Iki_Test_Pw!
SERVICE_ACCOUNT_DB_PASSWORD=SvcAcct_Iki_Test_Pw!